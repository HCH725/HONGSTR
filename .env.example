# EXECUTION MODES
# A=Backtest, B=Paper, C=Testnet
EXECUTION_MODE=B
OFFLINE_MODE=false

# BINANCE API (Required for Testnet/C)
BINANCE_API_KEY=your_key
BINANCE_API_SECRET=your_secret
BINANCE_TESTNET_BASE_URL=https://testnet.binancefuture.com

# REALTIME (C7)
REALTIME_ENABLED=true
REALTIME_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT
REALTIME_STREAMS=aggTrade,kline_1m

# SIGNALS (C8)
SIGNAL_ENABLED=true
SIGNAL_OUTPUT_ROOT=data/signals

# RISK (C11)
MAX_ORDER_NOTIONAL=5000.0
MAX_TOTAL_EXPOSURE=50000.0
LEVERAGE_DEFAULT=2

# SMOKE TEST (C13)
SMOKE_TESTNET_ENABLED=true
SMOKE_NOTIONAL_USD=60.0

# TELEGRAM / ALERTS
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
