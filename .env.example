# NOTE: Canonical Binance keys are BINANCE_API_KEY and BINANCE_API_SECRET.
# Compatibility: BINANCE_SECRET_KEY is also supported and will be aliased.
# EXECUTION MODES
# A=Backtest, B=Paper, C=Testnet
EXECUTION_MODE=B
OFFLINE_MODE=false

# BINANCE API (Required for Testnet/C)
BINANCE_API_KEY=your_key
BINANCE_API_SECRET=your_secret
# Optional legacy alias (scripts/load_env.sh mirrors this to BINANCE_API_SECRET)
BINANCE_SECRET_KEY=
BINANCE_TESTNET_BASE_URL=https://testnet.binancefuture.com

# OKX API (Optional for public data; required for private/account data)
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_BASE_URL=https://www.okx.com

# BITFINEX API (Optional for public data; required for private/account data)
BITFINEX_API_KEY=
BITFINEX_API_SECRET=
BITFINEX_BASE_URL=https://api-pub.bitfinex.com

# REALTIME (C7)
REALTIME_ENABLED=true
REALTIME_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT
REALTIME_STREAMS=aggTrade,kline_1m

# SIGNALS (C8)
SIGNAL_ENABLED=true
SIGNAL_OUTPUT_ROOT=data/signals

# RISK (C11)
MAX_ORDER_NOTIONAL=5000.0
MAX_TOTAL_EXPOSURE=50000.0
LEVERAGE_DEFAULT=2

# SMOKE TEST (C13)
SMOKE_TESTNET_ENABLED=true
SMOKE_NOTIONAL_USD=60.0

# TELEGRAM / ALERTS
# Preferred keys used by scripts/notify_telegram.sh
TG_BOT_TOKEN=
TG_CHAT_ID=
TG_PARSE_MODE=Markdown
TG_DISABLE=0
TG_TIMEOUT=8

# Backward-compat aliases (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
