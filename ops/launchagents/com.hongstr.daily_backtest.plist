<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.hongstr.daily_backtest</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>cd __REPO_ROOT__ &amp;&amp; source scripts/load_env.sh &amp;&amp; bash scripts/daily_backtest.sh</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key><integer>5</integer>
    <key>Minute</key><integer>0</integer>
  </dict>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>__REPO_ROOT__/logs/launchd_daily_backtest.out.log</string>
  <key>StandardErrorPath</key>
  <string>__REPO_ROOT__/logs/launchd_daily_backtest.err.log</string>

  <key>ThrottleInterval</key>
  <integer>60</integer>
</dict>
</plist>
