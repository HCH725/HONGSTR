<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.hongstr.research_loop</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/hong/Projects/HONGSTR/scripts/run_research_loop.sh</string>
        <string>--once</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>20</integer>
    </dict>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>PYTHONPATH</key>
        <string>/Users/hong/Projects/HONGSTR</string>
    </dict>

    <key>WorkingDirectory</key>
    <string>/Users/hong/Projects/HONGSTR</string>

    <key>StandardOutPath</key>
    <string>/Users/hong/Projects/HONGSTR/logs/launchd_research_loop.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/hong/Projects/HONGSTR/logs/launchd_research_loop.err.log</string>

    <key>RunAtLoad</key>
    <false/>

    <key>KeepAlive</key>
    <false/>
</dict>
</plist>
